#!/usr/bin/env bash
# Copy to .git/hooks/pre-commit (repo root) — optional fast gate.
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
echo "pre-commit: Vitest coverage + enforce-98 (set SKIP_COVERAGE_PRE_COMMIT=1 to skip)"
if [[ "${SKIP_COVERAGE_PRE_COMMIT:-0}" == "1" ]]; then
  echo "SKIP_COVERAGE_PRE_COMMIT=1 — skipping" >&2
  exit 0
fi
pnpm run test:coverage:all >/dev/null
pnpm run coverage:enforce-98
echo "pre-commit: coverage OK"
