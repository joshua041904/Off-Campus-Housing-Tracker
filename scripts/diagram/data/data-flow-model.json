{
  "title": "Cross-service data flow (HTTP/gRPC + Kafka + OTEL + Prometheus + Ollama)",
  "description": "Curated topology. Kafka brokers nested under data plane. Optional KAFKA_BROKER_STATUS_JSON merges broker health. Observability: Prometheus scrape + alert/recording rules, Jaeger via OTLP, gRPC interceptors propagate trace context on gateway→service calls. Ollama: optional LLM for analytics listing-feel.",
  "kafka_cluster": {
    "brokers": [
      { "id": "kb0", "label": "broker-0" },
      { "id": "kb1", "label": "broker-1" },
      { "id": "kb2", "label": "broker-2" }
    ]
  },
  "clusters": [
    {
      "id": "edge",
      "label": "Edge",
      "nodes": ["gateway", "caddy"]
    },
    {
      "id": "svc",
      "label": "Application services",
      "nodes": [
        "auth",
        "listings",
        "bookings",
        "messaging",
        "notification",
        "trust",
        "analytics",
        "media",
        "event_layer"
      ]
    },
    {
      "id": "llm",
      "label": "Optional LLM",
      "nodes": ["ollama"]
    },
    {
      "id": "data",
      "label": "Data plane",
      "nodes": ["postgres_fleet"]
    },
    {
      "id": "observe",
      "label": "Observability",
      "nodes": ["prometheus", "jaeger"]
    }
  ],
  "labels": {
    "gateway": "API Gateway",
    "caddy": "Caddy (TLS / HTTP3)",
    "auth": "Auth",
    "listings": "Listings",
    "bookings": "Bookings",
    "messaging": "Messaging",
    "notification": "Notification",
    "trust": "Trust",
    "analytics": "Analytics",
    "media": "Media",
    "event_layer": "Event layer",
    "ollama": "Ollama\n(listing-feel)",
    "postgres_fleet": "Postgres (per-service DBs)",
    "prometheus": "Prometheus\n+ alert rules",
    "jaeger": "Jaeger\n(OTLP traces)",
    "kb0": "broker-0",
    "kb1": "broker-1",
    "kb2": "broker-2"
  },
  "edges": [
    { "from": "caddy", "to": "gateway", "label": "TLS terminate" },
    { "from": "gateway", "to": "auth", "label": "HTTP/gRPC + OTEL\n(gRPC interceptors)" },
    { "from": "gateway", "to": "listings", "label": "HTTP/gRPC + OTEL\n(gRPC interceptors)" },
    { "from": "gateway", "to": "bookings", "label": "HTTP/gRPC + OTEL\n(gRPC interceptors)" },
    { "from": "gateway", "to": "messaging", "label": "HTTP/gRPC + OTEL\n(gRPC interceptors)" },
    { "from": "gateway", "to": "media", "label": "HTTP/gRPC + OTEL\n(gRPC interceptors)" },
    { "from": "listings", "to": "postgres_fleet", "label": "SQL" },
    { "from": "bookings", "to": "postgres_fleet", "label": "SQL" },
    { "from": "messaging", "to": "postgres_fleet", "label": "SQL" },
    { "from": "auth", "to": "postgres_fleet", "label": "SQL" },
    { "from": "notification", "to": "postgres_fleet", "label": "SQL" },
    { "from": "trust", "to": "postgres_fleet", "label": "SQL" },
    { "from": "analytics", "to": "postgres_fleet", "label": "SQL" },
    { "from": "media", "to": "postgres_fleet", "label": "SQL" },
    { "from": "event_layer", "to": "kb0", "label": "produce", "style": "dashed" },
    { "from": "listings", "to": "kb0", "label": "domain events", "style": "dashed" },
    { "from": "bookings", "to": "kb0", "label": "domain events", "style": "dashed" },
    { "from": "messaging", "to": "kb0", "label": "domain events", "style": "dashed" },
    { "from": "kb0", "to": "analytics", "label": "consume", "style": "dashed" },
    { "from": "kb0", "to": "notification", "label": "consume", "style": "dashed" },
    { "from": "kb0", "to": "trust", "label": "consume", "style": "dashed" },
    { "from": "analytics", "to": "ollama", "label": "HTTP\n(listing-feel)", "style": "dashed" },
    { "from": "gateway", "to": "prometheus", "label": "/metrics scrape", "style": "dotted" },
    { "from": "gateway", "to": "jaeger", "label": "OTLP traces", "style": "dotted" },
    { "from": "kb0", "to": "jaeger", "label": "trace headers\non records", "style": "dotted" },
    { "from": "postgres_fleet", "to": "prometheus", "label": "exporter / sql metrics", "style": "dotted" },
    { "from": "analytics", "to": "prometheus", "label": "/metrics", "style": "dotted" }
  ]
