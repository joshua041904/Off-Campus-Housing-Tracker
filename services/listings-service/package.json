{
  "name": "listings-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "ROLLUP_DISABLE_NATIVE=true KAFKAJS_NO_PARTITIONER_WARNING=1 vitest run",
    "test:integration": "ROLLUP_DISABLE_NATIVE=true KAFKAJS_NO_PARTITIONER_WARNING=1 vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm run test && pnpm run test:integration",
    "test:watch": "ROLLUP_DISABLE_NATIVE=true KAFKAJS_NO_PARTITIONER_WARNING=1 vitest"
  },
  "dependencies": {
    "@common/utils": "workspace:*",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "dotenv": "^16.3.0",
    "express": "^4.19.2",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
