{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": ["src/proxy-limits.ts", "src/cluster-weight-budget.ts", "src/gateway-traffic-skip.ts"],
  "thresholds": { "high": 90, "low": 80, "break": 85 },
  "concurrency": 2
}
