{
  "name": "booking-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "ROLLUP_DISABLE_NATIVE=true vitest run",
    "test:watch": "ROLLUP_DISABLE_NATIVE=true vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@common/utils": "workspace:*",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "@prisma/client": "6.17.1",
    "express": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "prisma": "6.17.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
