  },
  "dependencies": {
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
