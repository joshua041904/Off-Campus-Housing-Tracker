{
  "name": "off-campus-housing-tracker",
  "private": true,
  "version": "0.4.0",
  "workspaces": [
    "services/*",
    "webapp"
  ],
  "packageManager": "pnpm@9.11.0",
  "pnpm": {
    "overrides": {
      "@smithy/types": "^4.13.1"
    }
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm --filter @common/utils --filter media-service --filter messaging-service --filter event-layer-verification run test",
    "test:integration": "pnpm --filter messaging-service --filter media-service run test:integration",
    "lint": "pnpm -r lint || true",
    "format": "pnpm -r format || true",
    "full-pipeline": "bash scripts/run-full-pipeline.sh",
    "run-full-pipeline": "bash scripts/run-full-pipeline.sh",
    "reissue": "bash scripts/reissue-ca-and-leaf-load-all-services.sh",
    "kafka-ssl": "bash scripts/kafka-ssl-from-dev-root.sh",
    "verify-tls": "bash scripts/verify-caddy-strict-tls.sh",
    "preflight-and-suites": "bash scripts/run-preflight-scale-and-all-suites.sh",
    "test:webapp:e2e": "pnpm --filter webapp test:e2e"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.2",
    "otplib": "^12.0.1"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "compression": "^1",
    "cors": "^2",
    "dotenv": "^17.2.3",
    "helmet": "^7",
    "pg": "^8.12.0"
  }
}
