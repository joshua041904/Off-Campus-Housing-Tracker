{
  "name": "off-campus-housing-tracker",
  "private": true,
  "version": "0.4.0",
  "workspaces": [
    "services/*",
    "webapp"
  ],
  "packageManager": "pnpm@9.11.0",
  "pnpm": {
    "overrides": {
      "@smithy/types": "^4.13.1"
    }
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm --filter @common/utils --filter auth-service --filter api-gateway --filter booking-service --filter listings-service --filter analytics-service --filter trust-service --filter notification-service --filter cron-jobs --filter media-service --filter messaging-service --filter event-layer-verification run test",
    "test:integration": "pnpm --filter messaging-service --filter media-service run test:integration",
    "lint": "pnpm -r lint || true",
    "format": "pnpm -r format || true",
    "full-pipeline": "bash scripts/run-full-pipeline.sh",
    "run-full-pipeline": "bash scripts/run-full-pipeline.sh",
    "reissue": "bash scripts/reissue-ca-and-leaf-load-all-services.sh",
    "rebuild:och:rollout": "bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:housing:colima": "bash scripts/rebuild-housing-colima.sh",
    "rebuild:service:auth": "SERVICES=auth-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:trust": "SERVICES=trust-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:listings": "SERVICES=listings-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:analytics": "SERVICES=analytics-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:media": "SERVICES=media-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:search": "SERVICES=listings-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:gateway:rollout": "SERVICES=api-gateway bash scripts/rebuild-och-images-and-rollout.sh",
    "kafka-ssl": "bash scripts/kafka-ssl-from-dev-root.sh",
    "verify-tls": "bash scripts/verify-caddy-strict-tls.sh",
    "preflight-and-suites": "bash scripts/run-preflight-scale-and-all-suites.sh",
    "setup:full-stack": "bash scripts/setup-full-off-campus-housing-stack.sh",
    "make:help": "make help",
    "demo": "make demo",
    "demo:network": "make demo-network",
    "demo:full": "make demo-full",
    "test:event-layer": "bash scripts/run-event-layer-verification.sh",
    "test:e2e:preflight": "bash scripts/run-playwright-e2e-preflight.sh",
    "test:e2e:integrated": "bash scripts/run-playwright-e2e-preflight.sh",
    "bench:redis-lua": "bash scripts/benchmark-redis-lua-vs-plain.sh",
    "test:webapp:e2e": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test",
    "test:webapp:e2e:smoke": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=01-guest-shell --project=04-analytics",
    "test:webapp:e2e:listings": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=03-listings",
    "test:webapp:e2e:auth-booking": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=02-auth-booking",
    "test:housing-wiring": "bash scripts/test-housing-stack-wiring.sh",
    "k6:listings:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-concurrency.js'",
    "k6:messaging:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-messaging-concurrency.js'",
    "k6:analytics:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-analytics-concurrency.js'",
    "k6:booking:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-booking-concurrency.js'",
    "k6:trust:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-trust-concurrency.js'",
    "k6:media:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-media-concurrency.js'",
    "k6:listings:search-slowpath": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-search-slowpath.js'",
    "k6:dual:contention": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/perf/k6-dual-service-contention.js'",
    "k6:listings:malformed": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-malformed.js'"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.2",
    "otplib": "^12.0.1"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "compression": "^1",
    "cors": "^2",
    "dotenv": "^17.2.3",
    "helmet": "^7",
    "pg": "^8.12.0"
  }
}
