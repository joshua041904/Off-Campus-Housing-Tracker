{
  "name": "off-campus-housing-tracker",
  "private": true,
  "version": "0.4.0",
  "workspaces": [
    "services/*",
    "webapp",
    "tools/kafka-contract"
  ],
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@smithy/types": "^4.13.1",
      "rollup": "npm:@rollup/wasm-node@4.9.6"
    },
    "supportedArchitectures": {
      "os": ["darwin", "linux"],
      "cpu": ["arm64", "x64"]
    }
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel dev",
    "test": "ROLLUP_DISABLE_NATIVE=true pnpm --filter @common/utils --filter auth-service --filter api-gateway --filter booking-service --filter listings-service --filter analytics-service --filter trust-service --filter notification-service --filter cron-jobs --filter media-service --filter messaging-service --filter event-layer-verification run test",
    "test:integration": "ROLLUP_DISABLE_NATIVE=true pnpm --filter messaging-service --filter media-service run test:integration",
    "test:integration:all": "pnpm -C services/analytics-service run test:integration && pnpm -C services/messaging-service run test:integration && pnpm -C services/media-service run test:integration && pnpm -C services/trust-service run test:integration && node scripts/assert-kafka-integration-cluster.mjs && pnpm -C services/listings-service run test:integration && pnpm -C services/booking-service run test:integration",
    "test:system": "bash scripts/run-vitest-system.sh",
    "test:observability": "vitest run --config vitest.observability.config.mts",
    "test:vitest-stack": "pnpm run test:integration:all && pnpm run test:system && ROLLUP_DISABLE_NATIVE=true pnpm run test",
    "test:coverage:all": "ROLLUP_DISABLE_NATIVE=true node scripts/coverage/run-coverage-manifest.mjs",
    "test:coverage:preflight-parity": "ROLLUP_DISABLE_NATIVE=true OCH_COVERAGE_POST_STACK=1 node scripts/coverage/run-coverage-manifest.mjs",
    "test:coverage:open": "bash scripts/open-service-coverage-html.sh",
    "test:smoke": "ROLLUP_DISABLE_NATIVE=true pnpm run test && pnpm run test:integration:all && pnpm run test:system",
    "verify:bootstrap-state": "VERIFY_BOOTSTRAP_CONTEXT=ci node scripts/verify-bootstrap-state.mjs --json-out bench_logs/bootstrap-state-verify-latest.json",
    "coverage-report": "node scripts/coverage/verify-api-docs.mjs && node scripts/coverage/och-coverage-model-v1.mjs && node scripts/coverage/och-service-coverage-matrix.mjs",
    "coverage:report": "pnpm run coverage-report",
    "verify:api-docs": "node scripts/coverage/verify-api-docs.mjs",
    "coverage:vitest-aggregate": "node scripts/coverage/vitest-aggregate-coverage.mjs",
    "coverage:enforce-98": "node scripts/coverage/enforce-98.mjs",
    "coverage:hard-gate": "pnpm run test:coverage:all && pnpm run coverage:enforce-98 && mkdir -p bench_logs && pnpm run coverage:scan-gaps -- --json-out=bench_logs/coverage-gaps.json",
    "coverage:scan-gaps": "node scripts/coverage/scan-gaps.mjs",
    "coverage:update-baseline": "node scripts/coverage/update-baseline.mjs",
    "gen:route-smoke-tests": "node scripts/testing/generate-route-smoke-tests.mjs",
    "coverage:heatmap": "node scripts/coverage/coverage-branch-heatmap.mjs",
    "observability:chaos-score": "node scripts/observability/chaos-resilience-score.mjs",
    "observability:trace-temporal": "node scripts/observability/trace-temporal-invariants.mjs",
    "observability:dci": "node scripts/observability/distributed-correctness-index.mjs",
    "mutation:test:api-gateway": "pnpm -C services/api-gateway exec stryker run",
    "mutation:test:auth-service": "pnpm -C services/auth-service exec stryker run",
    "coverage:matrix-services": "bash scripts/coverage/run-matrix-vitest-coverage.sh",
    "report:matrix-local": "bash scripts/coverage/run-full-matrix-local-report.sh",
    "coverage:phase-vi2-verify": "bash scripts/coverage/run-phase-vi2-matrix-verify.sh",
    "k6:coverage-warmup": "make k6-coverage-warmup",
    "preflight:lab-report": "node scripts/coverage/generate-preflight-lab-report.mjs",
    "validate-observability": "node scripts/trace-validators/run-step7-observability-gates.mjs --report-dir bench_logs/step7-observability-ci",
    "trace-contract:fixture": "node scripts/validate-trace-contract.mjs --fixture scripts/trace-validators/fixtures/trace-contract-pass.json",
    "get-all-services": "node scripts/get-all-services.mjs",
    "trace-contract": "bash scripts/trace-contract-test.sh",
    "validate:trace-propagation": "node scripts/trace-validators/validate-trace-propagation-under-load.mjs --report-dir bench_logs/trace-propagation-proof",
    "observability:drift-append": "node scripts/observability-drift-append.mjs",
    "test:account-deletion-e2e": "vitest run --config vitest.account-deletion.config.ts",
    "lint": "pnpm -r lint || true",
    "format": "pnpm -r format || true",
    "full-pipeline": "bash scripts/run-full-pipeline.sh",
    "run-full-pipeline": "bash scripts/run-full-pipeline.sh",
    "reissue": "bash scripts/reissue-ca-and-leaf-load-all-services.sh",
    "rebuild:och:rollout": "bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:housing:all:k3s": "bash scripts/rebuild-all-housing-images-k3s.sh",
    "rebuild:housing:colima": "bash scripts/rebuild-housing-colima.sh",
    "rebuild:service:analytics": "SERVICES=analytics-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:auth": "SERVICES=auth-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:booking": "SERVICES=booking-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:cron": "SERVICES=cron-jobs bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:listings": "SERVICES=listings-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:media": "SERVICES=media-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:messaging": "SERVICES=messaging-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:notification": "SERVICES=notification-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:search": "SERVICES=listings-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:trust": "SERVICES=trust-service bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:service:watchdog": "SERVICES=transport-watchdog bash scripts/rebuild-och-images-and-rollout.sh",
    "rebuild:gateway:rollout": "SERVICES=api-gateway bash scripts/rebuild-och-images-and-rollout.sh",
    "kafka-ssl": "bash scripts/kafka-ssl-from-dev-root.sh",
    "verify-tls": "bash scripts/verify-caddy-strict-tls.sh",
    "preflight-and-suites": "bash scripts/run-preflight-scale-and-all-suites.sh",
    "setup:full-stack": "bash scripts/setup-full-off-campus-housing-stack.sh",
    "make:help": "make help",
    "demo": "make demo",
    "demo:network": "make demo-network",
    "demo:full": "make demo-full",
    "kafka-contract:build": "pnpm --filter kafka-contract run build",
    "kafka-contract:validate": "bash scripts/run-kafka-contract-validate.sh",
    "verify:kafka-kraft-e2e": "bash scripts/verify-kafka-kraft-e2e.sh",
    "verify:kafka-bootstrap": "bash scripts/verify-housing-kafka-bootstrap.sh",
    "verify:kafka-tls-sans": "bash scripts/verify-kafka-tls-sans.sh",
    "verify:kafka-kraft-advertised": "bash scripts/verify-kafka-kraft-advertised-listeners.sh",
    "verify:kafka-cluster": "bash scripts/verify-kafka-cluster.sh",
    "verify:preflight-edge-routing": "bash scripts/verify-preflight-edge-routing.sh",
    "colima:api-health": "bash scripts/colima-api-health.sh",
    "colima:forward-6443": "bash scripts/colima-forward-6443.sh",
    "test:event-layer": "bash scripts/run-event-layer-verification.sh",
    "test:e2e:preflight": "bash scripts/run-playwright-e2e-preflight.sh",
    "test:e2e:integrated": "bash scripts/run-playwright-e2e-preflight.sh",
    "bench:redis-lua": "bash scripts/benchmark-redis-lua-vs-plain.sh",
    "test:webapp:e2e": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test",
    "test:webapp:e2e:full-strict": "pnpm --filter webapp run test:e2e:full-matrix-strict",
    "test:webapp:e2e:smoke": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=01-guest-shell --project=04-analytics",
    "test:webapp:e2e:listings": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=03-listings",
    "test:webapp:e2e:auth-booking": "NODE_EXTRA_CA_CERTS=$PWD/certs/dev-root.pem pnpm --filter webapp exec playwright test --project=02-auth-booking",
    "load:ui-analytics": "bash scripts/load/playwright-analytics-ui-warmup.sh",
    "test:housing-wiring": "bash scripts/test-housing-stack-wiring.sh",
    "k6:listings:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-concurrency.js'",
    "k6:messaging:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-messaging-concurrency.js'",
    "k6:messaging:direct": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-messaging-direct-message.js'",
    "k6:analytics:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-analytics-concurrency.js'",
    "k6:booking:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-booking-concurrency.js'",
    "k6:trust:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-trust-concurrency.js'",
    "k6:media:concurrency": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-media-concurrency.js'",
    "k6:listings:search-slowpath": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-search-slowpath.js'",
    "k6:dual:contention": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/perf/k6-dual-service-contention.js'",
    "k6:listings:malformed": "bash -c 'SSL_CERT_FILE=\"${SSL_CERT_FILE:-$PWD/certs/dev-root.pem}\" k6 run scripts/load/k6-listings-malformed.js'"
  },
  "devDependencies": {
    "@common/utils": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.2",
    "@vitest/coverage-v8": "2.1.9",
    "kafkajs": "^2.2.4",
    "otplib": "^12.0.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "compression": "^1",
    "cors": "^2",
    "dotenv": "^17.2.3",
    "helmet": "^7",
    "pg": "^8.12.0"
  }
}
