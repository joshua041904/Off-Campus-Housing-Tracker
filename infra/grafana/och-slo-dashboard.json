          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{protocol=\"http1\"}[5m])) by (le, service)) / clamp_min(histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{protocol=\"http2\"}[5m])) by (le, service)), 0.001)",
