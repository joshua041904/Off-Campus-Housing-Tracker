{
  "title": "OCH — Cluster stability (stub)",
  "uid": "och-cluster-stability",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["och", "kubernetes", "restarts"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Pod restart rate (requires kube-state-metrics)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (namespace) (rate(kube_pod_container_status_restarts_total[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-6h", "to": "now" }
}
