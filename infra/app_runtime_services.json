{
  "version": "3",
  "namespace": "off-campus-housing-tracker",
  "defaults": {
    "retries": 10,
    "backoff_initial_seconds": 2,
    "backoff_max_seconds": 60,
    "rollout_timeout_seconds": 120,
    "health_connect_timeout_seconds": 3,
    "health_max_time_seconds": 12,
    "parallelism": 8
  },
  "services": [
    {
      "name": "api-gateway",
      "port": 4020,
      "health_path": "/healthz",
      "depends_on": ["auth-service", "listings-service"]
    },
    {
      "name": "auth-service",
      "port": 4011,
      "health_path": "/healthz",
      "health_type": "grpc",
      "grpc_port": 50061,
      "grpc_service": "auth.AuthService",
      "grpc_tls": true,
      "grpc_probe_binary": "/usr/local/bin/grpc-health-probe"
    },
    {
      "name": "listings-service",
      "port": 4012,
      "health_path": "/healthz",
      "health_type": "auto",
      "grpc_port": 50062,
      "grpc_service": "listings.ListingsService",
      "grpc_tls": true,
      "grpc_probe_binary": "/usr/local/bin/grpc-health-probe",
      "depends_on": []
    },
    {
      "name": "ollama",
      "port": 11434,
      "health_path": "/api/tags",
      "health_type": "http",
      "depends_on": [],
      "rollout_timeout_seconds": 1200
    },
    {
      "name": "ollama-gateway",
      "port": 8081,
      "health_path": "/metrics",
      "health_type": "http",
      "depends_on": ["ollama"],
      "rollout_timeout_seconds": 900
    },
    {
      "name": "analytics-service",
      "port": 4017,
      "health_path": "/healthz",
      "health_type": "auto",
      "grpc_port": 50067,
      "grpc_service": "analytics.AnalyticsService",
      "grpc_tls": true,
      "grpc_probe_binary": "/usr/local/bin/grpc-health-probe",
      "depends_on": ["ollama"]
    }
  ]
}
