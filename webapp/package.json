{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test",
    "test:e2e:01-guest-shell": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=01-guest-shell",
    "test:e2e:02-auth-booking": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=02-auth-booking",
    "test:e2e:03-listings": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=03-listings",
    "test:e2e:04-analytics": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=04-analytics",
    "test:e2e:05-screenshots": "E2E_SCREENSHOTS=1 NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=05-optional-screenshots",
    "test:e2e:06-verticals": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=06-service-verticals",
    "test:e2e:06-verticals:strict": "PLAYWRIGHT_VERTICAL_STRICT=1 PLAYWRIGHT_STRICT_HTTP3=1 NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=06-service-verticals",
    "test:e2e:07-system-integrity": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=07-system-integrity",
    "test:e2e:strict-verticals-and-integrity": "PLAYWRIGHT_VERTICAL_STRICT=1 PLAYWRIGHT_STRICT_HTTP3=1 NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=06-service-verticals --project=07-system-integrity",
    "test:e2e:smoke": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --project=01-guest-shell --project=04-analytics",
    "test:e2e:strict-edge": "sh ../scripts/webapp-playwright-strict-edge.sh",
    "test:e2e:ui": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --ui",
    "test:e2e:headed": "NODE_EXTRA_CA_CERTS=$PWD/../certs/dev-root.pem playwright test --headed"
  },
  "dependencies": {
    "react": "^18",
    "react-dom": "^18",
    "next": "14.2.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35"
  }
}
