# Copy to `.env.local` for local dev (that file is gitignored — do not commit keys).
#   cp .env.example .env.local
#   or: cp env.local.template .env.local  (same shape; Colima script reads this for Maps build-arg)
# Then set real values in `.env.local` only.

# Public (browser) — Google Maps Embed API key (restrict by HTTP referrer in Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# API gateway base (local dev often http://localhost:4020)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4020
