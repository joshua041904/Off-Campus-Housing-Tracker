# pnpm workspace (optional; used by api-gateway Dockerfile)
shamefully-hoist=false

# Rollup 4 + Vitest/Vite: prefer WASM bindings (avoids @rollup/rollup-* native ABI drift).
# pnpm does not inject arbitrary .npmrc keys into script environments — every vitest script also sets this explicitly.
ROLLUP_DISABLE_NATIVE=true
