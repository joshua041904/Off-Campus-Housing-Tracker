# pnpm workspace (optional; used by api-gateway Dockerfile)
shamefully-hoist=false

# Optional deps must stay enabled: esbuild (used by Vitest/Vite to load vitest.config.ts) installs
# @esbuild/darwin-* (etc.) as optionalDependencies. Disabling optionals breaks local Vitest on macOS.
# Apple Silicon + Rosetta: if Node runs as darwin-x64 but install was arm64-only, esbuild mismatches.
# Root package.json → pnpm.supportedArchitectures pulls both arm64 and x64 optional bins on darwin/linux;
# after changing it, run: pnpm install (prefer Terminal without Rosetta: arch → arm64, node -p process.arch → arm64).
# Rollup stays wasm-only via root package.json pnpm.overrides → @rollup/wasm-node; CI enforces no native
# @rollup/rollup-* under node_modules/.pnpm (scripts/ci/verify-no-rollup-native-packages.sh).

# Rollup 4 + Vitest/Vite: keep env hint for tools that read it (root override pins rollup → @rollup/wasm-node).
ROLLUP_DISABLE_NATIVE=true
