digraph physical {
  graph [rankdir=LR, fontsize=11, label="Physical: listings (listings)", labelloc=t];
  node [shape=record, fontname="Helvetica Neue"];
  edge [fontname="Helvetica Neue", fontsize=8];

  subgraph cluster_listings {
    style=filled;
    color=lightgrey;
    label="Schema: listings";
    "listings_listing_media" [label="{listing_media|id : uuid\llisting_id : uuid\lmedia_type : text\lurl_or_path : text\lsort_order : integer\lcreated_at : timestamp with time zone}"];
    "listings_listings" [label="{listings|id : uuid\luser_id : uuid\lusername_display : text\ltitle : text\llisted_at : date\lprice_cents : integer\llease_length_months : integer\lsize_sqft : integer\ldescription : text\lamenities : jsonb\lsmoke_free : boolean\lpet_friendly : boolean\lfurnished : boolean\leffective_from : date\leffective_until : date\lstatus : listings.listing_status}"];
    "listings_outbox_events" [label="{outbox_events|id : uuid\laggregate_id : text\ltype : text\lversion : integer\lpayload : bytea\lcreated_at : timestamp with time zone\lpublished : boolean}"];
    "listings_processed_events" [label="{processed_events|event_id : uuid\lprocessed_at : timestamp with time zone}"];
  }

  "listings_listing_media" -> "listings_listings" [label="listing_media_listing_id_fkey"];
}
