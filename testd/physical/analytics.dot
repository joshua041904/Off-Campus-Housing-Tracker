digraph physical {
  graph [rankdir=LR, fontsize=11, label="Physical: analytics (analytics)", labelloc=t];
  node [shape=record, fontname="Helvetica Neue"];
  edge [fontname="Helvetica Neue", fontsize=8];

  subgraph cluster_analytics {
    style=filled;
    color=lightgrey;
    label="Schema: analytics";
    "analytics_daily_metrics" [label="{daily_metrics|date : date\lnew_users : integer\lnew_listings : integer\lnew_bookings : integer\lcompleted_bookings : integer\lmessages_sent : integer\llistings_flagged : integer\lupdated_at : timestamp with time zone}"];
    "analytics_events" [label="{events|id : uuid\levent_type : text\levent_version : integer\lpayload : jsonb\lsource_service : text\lcreated_at : timestamp with time zone\levent_id : uuid}"];
    "analytics_listing_feel_cache" [label="{listing_feel_cache|id : uuid\lcontent_hash : text\laudience : text\lmodel : text\lanalysis_text : text\lcreated_at : timestamp with time zone}"];
    "analytics_processed_events" [label="{processed_events|event_id : uuid\lprocessed_at : timestamp with time zone}"];
    "analytics_projection_state" [label="{projection_state|projection_name : text\llast_processed_event_id : uuid\lupdated_at : timestamp with time zone}"];
    "analytics_projection_versions" [label="{projection_versions|name : text\lversion : integer\lupdated_at : timestamp with time zone}"];
    "analytics_recommendation_experiments" [label="{recommendation_experiments|id : integer\lname : text\lmodel_id : integer\ltraffic_percentage : integer\lis_active : boolean\lcreated_at : timestamp with time zone}"];
    "analytics_recommendation_models" [label="{recommendation_models|id : integer\lname : text\lversion : text\lis_active : boolean\lcreated_at : timestamp with time zone}"];
    "analytics_recommendation_weights" [label="{recommendation_weights|model_id : integer\ldistance : numeric\lprice : numeric\lpopularity : numeric\ltrust : numeric\lrecency : numeric}"];
    "analytics_user_activity" [label="{user_activity|user_id : uuid\llistings_created : integer\lbookings_made : integer\lmessages_sent : integer\lupdated_at : timestamp with time zone}"];
    "analytics_user_listing_engagement" [label="{user_listing_engagement|user_id : uuid\llisting_id : uuid\lmessages_sent : integer\lbookings : integer\llast_interaction_at : timestamp with time zone}"];
    "analytics_user_watchlist_daily" [label="{user_watchlist_daily|user_id : uuid\lday : date\ladds : integer\lremoves : integer\lupdated_at : timestamp with time zone}"];
  }

  "analytics_recommendation_experiments" -> "analytics_recommendation_models" [label="recommendation_experiments_model_id_fkey"];
  "analytics_recommendation_weights" -> "analytics_recommendation_models" [label="recommendation_weights_model_id_fkey"];
}
