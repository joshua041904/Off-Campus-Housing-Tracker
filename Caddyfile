# -----------------------------------------------------------------------------
# Off-Campus-Housing-Tracker — production-grade Caddy (network spine lock)
# SNI: off-campus-housing.local only. No record-local; no protocol ambiguity.
# Data path: Caddy → services directly (no ingress-nginx in path).
# -----------------------------------------------------------------------------
{
	admin 0.0.0.0:2019
	grace_period 15s
	shutdown_delay 10s
	# Structured logging for observability; monitor {http.request.proto} {http.request.host} {http.request.tls.version} for H2 vs H3
	log {
		output stdout
		format json
		level INFO
	}
	servers {
		protocols h1 h2 h3
		timeouts {
			idle 2m
			read_body 2m
			write 2m
		}
		enable_full_duplex
	}
}

# Primary vhost — HTTP/3, REST, gRPC. Deterministic routing; no regex; SNI enforced.
# Caddy → api-gateway:4020, auth:4011, Envoy:10000 (housing ports per README — no conflict with record platform).
https://off-campus-housing.local {
	tls /etc/caddy/certs/tls.crt /etc/caddy/certs/tls.key {
		protocols tls1.2 tls1.3
		ciphers TLS_AES_128_GCM_SHA256 TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
	}

	# Request log: proto, host, tls version for H2 vs H3 comparison
	log request_access {
		output stdout
		format json
		level INFO
	}

	# SNI enforcement: wrong host → 421 Misdirected Request
	@wrong_host not host off-campus-housing.local
	handle @wrong_host {
		respond "Invalid Host" 421
	}

	# Health (before routing). respond short-circuits pipeline so Caddy does not inject alt-svc; add it explicitly so healthz advertises HTTP/3.
	handle_path /_caddy/healthz {
		header {
			alt-svc "h3=\":443\"; ma=2592000"
		}
		respond "ok" 200
	}

	# Privacy and Terms → auth-service (housing port 4011 per README)
	@privacy path /privacy
	handle @privacy {
		reverse_proxy http://auth-service.off-campus-housing-tracker.svc.cluster.local:4011 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up Traceparent {http.request.header.Traceparent}
			header_up Tracestate {http.request.header.Tracestate}
		}
	}

	@terms path /terms
	handle @terms {
		reverse_proxy http://auth-service.off-campus-housing-tracker.svc.cluster.local:4011 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up Traceparent {http.request.header.Traceparent}
			header_up Tracestate {http.request.header.Tracestate}
		}
	}

	# gRPC: deterministic match on Content-Type (no path regex). HTTP/2 only.
	@grpc header Content-Type application/grpc*
	handle @grpc {
		reverse_proxy envoy-test.envoy-test.svc.cluster.local:10000 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up Traceparent {http.request.header.Traceparent}
			header_up Tracestate {http.request.header.Tracestate}
			transport http {
				versions h2c
			}
		}
	}

	# REST API: explicit path list (no regex). Exclude gRPC by Content-Type.
	@api {
		path /api/* /auth/* /listings/* /booking/* /messaging/* /analytics/* /trust/*
		not header Content-Type application/grpc*
	}
	handle @api {
		reverse_proxy http://api-gateway.off-campus-housing-tracker.svc.cluster.local:4020 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Request-Id {http.request.id}
			header_up Traceparent {http.request.header.Traceparent}
			header_up Tracestate {http.request.header.Tracestate}
			transport http {
				versions h1
				dial_timeout 10s
				response_header_timeout 30s
				expect_continue_timeout 5s
			}
			lb_policy round_robin
			health_uri /healthz
			health_interval 30s
			health_timeout 5s
			fail_duration 30s
			max_fails 3
		}
	}

	# Web / static: explicit catch-all to api-gateway (housing port 4020 per README)
	@web path /*
	handle @web {
		reverse_proxy http://api-gateway.off-campus-housing-tracker.svc.cluster.local:4020 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Request-Id {http.request.id}
			header_up Traceparent {http.request.header.Traceparent}
			header_up Tracestate {http.request.header.Tracestate}
			transport http {
				versions h1
				dial_timeout 10s
				response_header_timeout 30s
			}
			health_uri /healthz
			health_interval 30s
			health_timeout 5s
		}
	}
}

# Fallback for port 443 with other SNI / no SNI — 421 Misdirected Request (no silent proxy)
:443 {
	tls /etc/caddy/certs/tls.crt /etc/caddy/certs/tls.key {
		protocols tls1.2 tls1.3
		ciphers TLS_AES_128_GCM_SHA256 TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
	}

	# Health for probes without correct SNI (alt-svc so verify script sees h3 advertised)
	handle_path /_caddy/healthz {
		header {
			alt-svc "h3=\":443\"; ma=2592000"
		}
		respond "ok" 200
	}

	# Wrong or missing SNI → 421 (no silent forward to api-gateway)
	handle {
		respond "Misdirected Request" 421
	}
}
