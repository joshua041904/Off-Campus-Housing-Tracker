# -----------------------------------------------------------------------------
# Off-Campus-Housing-Tracker — production-grade Caddy (network spine lock)
# SNI: off-campus-housing.test only. No record-local; no protocol ambiguity.
# Data path: Caddy → services directly (no ingress-nginx in path).
# -----------------------------------------------------------------------------
{
	admin 0.0.0.0:2019
	grace_period 15s
	shutdown_delay 10s
	# Structured logging for observability; monitor {http.request.proto} {http.request.host} {http.request.tls.version} for H2 vs H3
	log {
		output stdout
		format json
		level INFO
	}
	servers {
		protocols h1 h2 h3
		# Longer idle/write under H3 multiplexing + parallel Playwright / load tools (avoid premature stream close).
		timeouts {
			idle 5m
			read_body 3m
			write 3m
		}
		enable_full_duplex
		# Avoid tight default header cap under large cookies / tracing headers during suite load.
		max_header_size 1MiB
	}
}

# Primary vhost — HTTP/3, REST, gRPC. Deterministic routing; no regex; SNI enforced.
# Caddy → api-gateway:4020, auth:4011, Envoy:10000 (housing ports per README — no conflict with record platform).
https://off-campus-housing.test {
	tls /etc/caddy/certs/tls.crt /etc/caddy/certs/tls.key {
		protocols tls1.2 tls1.3
		ciphers TLS_AES_128_GCM_SHA256 TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
	}

	# Request log: proto, host, tls version for H2 vs H3 comparison
	log request_access {
		output stdout
		format json
		level INFO
	}

	# SNI enforcement: wrong host → 421 Misdirected Request
	@wrong_host not host off-campus-housing.test
	handle @wrong_host {
		respond "Invalid Host" 421
	}

	# Health (before routing). respond short-circuits pipeline so Caddy does not inject alt-svc; add it explicitly so healthz advertises HTTP/3.
	handle_path /_caddy/healthz {
		header {
			alt-svc "h3=\":443\"; ma=2592000"
		}
		respond "ok" 200
	}

	# Privacy and Terms → auth-service (housing port 4011 per README)
	@privacy path /privacy
	handle @privacy {
		reverse_proxy http://auth-service.off-campus-housing-tracker.svc.cluster.local:4011 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
		}
	}

	@terms path /terms
	handle @terms {
		reverse_proxy http://auth-service.off-campus-housing-tracker.svc.cluster.local:4011 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
		}
	}

	# gRPC: deterministic match on Content-Type (no path regex). HTTP/2 only.
	@grpc header Content-Type application/grpc*
	handle @grpc {
		reverse_proxy envoy-test.envoy-test.svc.cluster.local:10000 {
			header_up Host {http.request.host}
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
			transport http {
				versions h2c
				dial_timeout 10s
				response_header_timeout 60s
				read_buffer 32MiB
				write_buffer 32MiB
				keepalive 2m
				keepalive_interval 30s
				keepalive_idle_conns 256
				keepalive_idle_conns_per_host 64
			}
		}
	}

	# Observability UIs — single MetalLB IP (Caddy); otel-collector stays ClusterIP only.
	# Jaeger: forward full /jaeger/* (QUERY_BASE_PATH=/jaeger).
	# Grafana: forward full /grafana/* — NO strip. grafana-deploy sets GF_SERVER_ROOT_URL=.../grafana/ and
	#   GF_SERVER_SERVE_FROM_SUB_PATH=true; stripping made upstream see "/" and broke assets / redirect loops.
	# Prometheus: forward full /prometheus/* — NO strip. prometheus-deploy sets --web.route-prefix=/prometheus/;
	#   stripping broke the UI and API under the edge path.
	@jaeger path /jaeger /jaeger/*
	handle @jaeger {
		reverse_proxy http://jaeger.observability.svc.cluster.local:16686 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {http.request.host}
			header_up X-Forwarded-For {http.request.remote.host}
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
			transport http {
				versions h1 h2
				dial_timeout 10s
				response_header_timeout 120s
			}
		}
	}

	# Exact path without trailing slash → 308 to slash URL (avoids broken relative assets / API base).
	@grafana_noslash path /grafana
	handle @grafana_noslash {
		redir /grafana/ 308
	}
	@prometheus_noslash path /prometheus
	handle @prometheus_noslash {
		redir /prometheus/ 308
	}

	@grafana path /grafana /grafana/*
	handle @grafana {
		reverse_proxy http://grafana.observability.svc.cluster.local:3000 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {http.request.host}
			header_up X-Forwarded-For {http.request.remote.host}
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
			flush_interval -1
			transport http {
				versions h1 h2
				dial_timeout 10s
				response_header_timeout 180s
			}
		}
	}

	@prometheus path /prometheus /prometheus/*
	handle @prometheus {
		reverse_proxy http://prometheus.observability.svc.cluster.local:9090 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {http.request.host}
			header_up X-Forwarded-For {http.request.remote.host}
			header_up X-Request-Id {http.request.id}
			header_up X-OCH-Edge-Proto {http.request.proto}
			transport http {
				versions h1 h2
				dial_timeout 10s
				response_header_timeout 120s
			}
		}
	}

	# REST API: explicit path list (no regex). Exclude gRPC by Content-Type.
	@api {
		path /api/* /auth/* /listings/* /booking/* /messaging/* /analytics/* /insights/* /trust/* /media/* /notification/*
		not header Content-Type application/grpc*
	}
	handle @api {
		# REST only (gRPC excluded by @api matcher) — safe to compress.
		encode gzip zstd
		reverse_proxy http://api-gateway.off-campus-housing-tracker.svc.cluster.local:4020 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
			# h1 + h2 to gateway: clients still use HTTP/2 and HTTP/3 to Caddy; upstream can speak ALPN h2 where supported.
			transport http {
				versions h1 h2
				dial_timeout 10s
				# listing-feel can wait on CPU-bound Ollama; avoid edge 504 before upstream responds
				response_header_timeout 300s
				expect_continue_timeout 5s
				read_buffer 32MiB
				write_buffer 32MiB
				keepalive 2m
				keepalive_interval 30s
				keepalive_idle_conns 256
				keepalive_idle_conns_per_host 64
			}
			lb_policy round_robin
			# No active upstream health checks: Caddy starts before api-gateway is ready and logs
			# "connection refused" until K8s readiness converges; rely on kube readiness + passive retries.
		}
	}

	# Web / static: explicit catch-all to web frontend via nginx.
	@web path /*
	handle @web {
		reverse_proxy http://nginx.off-campus-housing-tracker.svc.cluster.local:8080 {
			header_up Host {http.request.host}
			header_up X-Forwarded-Proto https
			header_up X-Request-Id {http.request.id}
			header_up traceparent {http.request.header.traceparent}
			header_up tracestate {http.request.header.tracestate}
			header_up X-OCH-Edge-Proto {http.request.proto}
			transport http {
				versions h1 h2
				dial_timeout 10s
				response_header_timeout 30s
			}
		}
	}
}

# Fallback for port 443 with other SNI / no SNI — 421 Misdirected Request (no silent proxy)
:443 {
	tls /etc/caddy/certs/tls.crt /etc/caddy/certs/tls.key {
		protocols tls1.2 tls1.3
		ciphers TLS_AES_128_GCM_SHA256 TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
	}

	# Health for probes without correct SNI (alt-svc so verify script sees h3 advertised)
	handle_path /_caddy/healthz {
		header {
			alt-svc "h3=\":443\"; ma=2592000"
		}
		respond "ok" 200
	}

	# Wrong or missing SNI → 421 (no silent forward to api-gateway)
	handle {
		respond "Misdirected Request" 421
	}
}
